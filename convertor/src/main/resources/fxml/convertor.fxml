<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18"
      alignment="CENTER"
      styleClass="root"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hub.ui.controllers.ConvertorController">

    <Label text="Unit Converter"
           styleClass="title"/>

    <TextField fx:id="inputField"
               promptText="Enter value (e.g. 100cm)"
               styleClass="input"/>

    <ComboBox fx:id="fromBox"
              styleClass="dropdown"/>

    <ComboBox fx:id="toBox"
              styleClass="dropdown"/>

    <Label fx:id="resultLabel"
           text="Result"
           styleClass="result"/>

</VBox>